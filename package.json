{
  "name": "one-click-tar",
  "displayName": "one-click-tar",
  "description": "Create tar archives from the explorer context menu",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
    "repository": {
    "type": "git",
    "url": "https://github.com/your-name/one-click-tar.git"
  },
  "extensionKind": ["workspace"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "tarMaker.createTar",
        "title": "Create .tar from Folder"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "tarMaker.createTar",
          "when": "explorerResourceIsFolder",
          "group": "7_modification"
        }
      ],
      "commandPalette": [
        {
          "command": "tarMaker.createTar",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
